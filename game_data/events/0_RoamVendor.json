        "only_once": false,
        "priority": 20,
        "_source": [
            "# For buying growth rate modifiers and trinkets.",
            "if;v('TutorialFirst')['Vendor'] != True",
            "  u;VendorWoman;Right",
            "  s;VendorWoman;Hello, welcome to the <red>Item Shop</>. You can buy a lot of useful things here.|My stock changes every month, so please check back often.|Please keep in mind that the item chosen will be <red>used immediately by the person buying it</>.",
            "  r;VendorWoman",
            "  s;;You can check the price and effect of an item by pressing the <red>INFO</> key.;;;hint",
            "  add_lore;Vendor",
            "  mlvar;TutorialFirst;it.update({'Vendor':True})",
            "end",
            "if;len(v('VendorStock')) == 0 and v('VendorVisit') == True",
            "  u;VendorWoman;Right",
            "  s;VendorWoman;Sorry, I don't have anything else left in stock.",
            "else",
            "  choice;Shopper;Who will shop today?;Lord|{v:LordName},Player|{v:JagenName};EntryType=type_unit;backable",
            "  if;v('Shopper') != 'BACK'",
            "    if;v('VendorVisit') == False",
            "      lvar;VendorStock;[]",
            "      for;CreateStock;range(0,5)",
            "        trigger_script;0 Vendor Choose Stock",
            "      endf",
            "      lvar;VendorVisit;True",
            "    end",
            "    if;v('Shopper') == 'Lord'",
            "      lvar;ShopperName;v('LordName')",
            "    else",
            "      lvar;ShopperName;v('JagenName')",
            "    end",
            "    trigger_script;0 Vendor Shop Menu",
            "    end",
            "  end",
            "end",
            "u;VendorWoman;Right",
            "s;VendorWoman;Drop in again.",
            "r;VendorWoman"
        ],
        "nid": "0 RoamVendor"
    }
]