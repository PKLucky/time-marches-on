[
    {
        "name": "Skill_Swap_Operations",
        "trigger": null,
        "level_nid": null,
        "condition": "True",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "game_var;EXIT_SKILL_SWAP;False",
            "game_var;AUX_STR;''",
            "if;v('LearnedSkills') != 'Empty_Skill_List'",
            "  if;v('UnitSelectedSkill') == 'Add_New_Skill'",
            "    game_var;AUX_STR;'Add,'",
            "  else",
            "    game_var;AUX_STR;'Swap,'",
            "  end",
            "end",
            "if;v('UnitSelectedSkill') != 'Add_New_Skill'",
            "  game_var;AUX_STR;v('AUX_STR') + 'Remove,'",
            "end",
            "choice;SkillSwapOperation;;{v:AUX_STR}Cancel;40;backable",
            "if;v('SkillSwapOperation') == 'Remove'",
            "  trigger_script;Global Skill_Swap_Remove;{unit}",
            "elif;v('SkillSwapOperation') == 'Add'",
            "  trigger_script;Global Skill_Swap_Add;{unit}",
            "elif;v('SkillSwapOperation') == 'Swap'",
            "  trigger_script;Global Skill_Swap_Replace;{unit}",
            "end"
        ],
        "nid": "Global Skill_Swap_Operations"
    }
]