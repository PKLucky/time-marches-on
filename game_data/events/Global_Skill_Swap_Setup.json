[
    {
        "name": "Skill_Swap_Setup",
        "trigger": null,
        "level_nid": null,
        "condition": "True",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "game_var;EXIT_SKILL_SWAP;True",
            "# Get skills equipped on unit",
            "game_var;EquippedSkills;','.join([s for s in u('{unit}').get_field('EquippedSkills')])",
            "if;len(unit.get_field('EquippedSkills')) == 0",
            "  game_var;EquippedSkills;'Add_New_Skill'",
            "elif;len(unit.get_field('EquippedSkills')) < 5",
            "  game_var;EquippedSkills;'{v:EquippedSkills},Add_New_Skill'",
            "end",
            "# Get skills unit has learned",
            "if;len(unit.get_field('LearnedSkills')) > len (unit.get_field('EquippedSkills'))",
            "  game_var;LearnedSkills;','.join([s for s in u('{unit}').get_field('LearnedSkills') if s not in unit.get_field('EquippedSkills')])",
            "else",
            "  game_var;LearnedSkills;'Empty_Skill_List'",
            "end",
            "# Create table of learned skills to equip/unequip",
            "table;UNIT_RIGHT_SKILLS;{v:LearnedSkills};Learned Skills;5,1;100;top_right;;type_skill;center",
            "choice;UnitSelectedSkill;Equipped Skills;{v:EquippedSkills};100;vertical;top_left;;Global Skill_Swap_Operations;type_skill;5,1;left;backable",
            "remove_table;UNIT_RIGHT_SKILLS",
            "if;v('EXIT_SKILL_SWAP') != True",
            "  trigger_script;Global Skill_Swap_Setup",
            "end"
        ],
        "nid": "Global Skill_Swap_Setup"
    }
]