[
    {
        "name": "RoamArmory",
        "trigger": "Armory",
        "level_nid": "0",
        "condition": "game.is_roam() == True",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "# How the player checks the convoy for any extra items they receive from events.",
            "if;v('TutorialFirst')['Armory'] != True",
            "  u;ArmoryMan;Right",
            "  s;ArmoryMan;Hey there. This is the <red>Armory</>. I sell <red>Skill Scrolls</> here.|Read a scroll, learn its Skill. Simple as that.|My stock changes every month, so come stop by often.|Keep in mind that the scroll you buy will be <red>used immediately by the person buying it</>.",
            "  r;ArmoryMan",
            "  s;;You can check the price and effect of an item by pressing the <red>INFO</> key.;;;hint",
            "  if;v('TutorialFirst')['Skills'] != True",
            "    s;;A unit can learn as many skills as they want, but can only equip <red>five</> at a time.;;;hint",
            "    s;;Skills can be configured by visiting the castle and selecting <red>Set Skills</>.;;;hint",
            "    add_lore;Skills",
            "  end",
            "  add_lore;Armory",
            "  mlvar;TutorialFirst;it.update({'Armory':True})",
            "  mlvar;TutorialFirst;it.update({'Skills':True})",
            "end",
            "if;len(v('ArmoryStock')) == 0 and v('ArmoryVisit') == True",
            "  u;ArmoryMan;Right",
            "  s;ArmoryMan;I'm all outta scrolls this month.",
            "else",
            "  choice;Shopper;Who's buyin'?;Lord|{v:LordName},Player|{v:JagenName};EntryType=type_unit;backable",
            "  if;v('Shopper') != 'BACK'",
            "    if;v('ArmoryVisit') == False",
            "      lvar;ArmoryStock;[]",
            "      for;CreateStock;range(0,5)",
            "        trigger_script;0 Armory Choose Stock",
            "      endf",
            "      lvar;ArmoryVisit;True",
            "    end",
            "    if;v('Shopper') == 'Lord'",
            "      lvar;ShopperName;v('LordName')",
            "    else",
            "      lvar;ShopperName;v('JagenName')",
            "    end",
            "    trigger_script;0 Armory Shop Menu",
            "    end",
            "  end",
            "end",
            "u;ArmoryMan;Right",
            "s;ArmoryMan;Come back again.",
            "r;ArmoryMan"
        ],
        "nid": "0 RoamArmory"
    }
]