[
    {
        "name": "Class Siblings Talk",
        "trigger": "ClassChange",
        "level_nid": "0",
        "condition": "True",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "lvar;SiblingKlass;''",
            "lvar;SiblingNid;''",
            "lvar;ChoiceMade;False",
            "if;region.nid == 'class0'",
            "  lvar;SiblingKlass;u('200').klass",
            "  lvar;SiblingNid;'200'",
            "elif;region.nid == 'class1'",
            "  lvar;SiblingKlass;u('201').klass",
            "  lvar;SiblingNid;'201'",
            "elif;region.nid == 'class2'",
            "  lvar;SiblingKlass;u('202').klass",
            "  lvar;SiblingNid;'202'",
            "elif;region.nid == 'class3'",
            "  lvar;SiblingKlass;u('203').klass",
            "  lvar;SiblingNid;'203'",
            "elif;region.nid == 'class4'",
            "  lvar;SiblingKlass;u('204').klass",
            "  lvar;SiblingNid;'204'",
            "elif;region.nid == 'class5'",
            "  lvar;SiblingKlass;u('205').klass",
            "  lvar;SiblingNid;'205'",
            "end",
            "if;v('TutorialFirst')['ClassChange'] != True",
            "  u;{v:SiblingKlass};Right;;Smile",
            "  s;{v:SiblingKlass};Hi! We're the <red>Re-Classy Siblings</>!|We can help you change your class into the class we're in.|{c:e;{v:SiblingKlass};NoSmile}When you change classes, you get <red>stat and growth rate adjustments</>.|You also earn <red>double Weapon Experience Points</> when wielding a compatible weapon.|However, if you decide to change into one of our classes,|<red>whichever sibling you talk to will leave the area</>. We've got other places to be, y'know?|{c:e;{v:SiblingKlass};Smile}But don't worry. We come back every month.|{c:e;{v:SiblingKlass};NoSmile}Speaking of which, you'll <red>go back to your base class at the end of the month</>.|{c:e;{v:SiblingKlass};NoSmile}So, keep talking to us if you want a change of pace!|Also, any class you re-class into will be <red>added to your re-classing options</> at the end of the year.",
            "  add_lore;Reclass",
            "  mlvar;TutorialFirst;it.update({'ClassChange':True})",
            "end",
            "end_skip",
            "if;v('TutorialFirst')['Dancer'] != True and v('SiblingKlass') == 'Dancer'",
            "  u;{v:SiblingKlass};Right;;Smile",
            "  s;{v:SiblingKlass};By the way, my class is special.|Both of you can be a <red>Dancer</> if you want. No restrictions here!|Just decide between the two of you who wants to become a Dancer,|then we can get the class change rolling, okay?",
            "  mlvar;TutorialFirst;it.update({'Dancer':True})",
            "end",
            "rrr",
            "u;{v:SiblingKlass};RightCorner",
            "if;v('SiblingKlass') == 'Dancer'",
            "  choice;DancerChoice;Who will change class?;Lord|{v:LordName},Player|{v:JagenName};EntryType=type_unit;backable",
            "  if;v('DancerChoice') == 'Lord'",
            "    trigger_script;0 Class Siblings Lord Choice",
            "  else",
            "    trigger_script;0 Class Siblings Jagen Choice",
            "  end",
            "elif;region.nid in ['class0','class1','class2']",
            "  trigger_script;0 Class Siblings Lord Choice",
            "else",
            "  trigger_script;0 Class Siblings Jagen Choice",
            "end",
            "remove_table;ClassInfoTable",
            "r;{v:SiblingKlass};immediate",
            "u;{v:SiblingKlass};Right;;Smile",
            "s;{v:SiblingKlass};See you later!",
            "rrr",
            "if;v('ChoiceMade') == True",
            "  remove;{v:SiblingNid};fade;fade",
            "  remove_region;{e:region.nid}",
            "end"
        ],
        "nid": "0 Class Siblings Talk"
    }
]