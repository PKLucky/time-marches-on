[
    {
        "name": "Fortune Telling",
        "trigger": null,
        "level_nid": "0",
        "condition": "True",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "lvar;FortuneUnitChoice;game.get_random(101,108)",
            "if;v('Fortunes')[v('FortuneUnitChoice')] == False",
            "  if;u('{v:FortuneUnitChoice}').get_weapon()",
            "    lvar;FortuneWeapon;u('{v:FortuneUnitChoice}').get_weapon().name",
            "  else",
            "    lvar;FortuneWeapon;u('{v:FortuneUnitChoice}').items[0].name",
            "  end",
            "  for;CheckSkill;[s for s in u('{v:FortuneUnitChoice}').skills]",
            "    if;game.get_skill({CheckSkill}).nid != 'HigherDifficulty' and game.get_skill({CheckSkill}).nid != 'Mounted_Mov' and game.get_skill({CheckSkill}).nid != 'Distance_Debuff' and game.get_skill({CheckSkill}).nid != 'Discipline'",
            "      lvar;FortuneSkill;game.get_skill({CheckSkill}).name",
            "      lvar;FortuneSkillDesc;game.get_skill({CheckSkill}).desc",
            "    end",
            "  endf",
            "  if;DB.classes.get(u('{v:FortuneUnitChoice}').klass).name in ['A','E','I','O','U']",
            "    lvar;ClassArticle;'an'",
            "  else",
            "    lvar;ClassArticle;'a'",
            "  end",
            "  if;v('FortuneWeapon')[0] in ['A','E','I','O','U']",
            "    lvar;WeaponArticle;'an'",
            "  else",
            "    lvar;WeaponArticle;'a'",
            "  end",
            "  u;OldWoman1;Right;;CloseEyes",
            "  s;OldWoman1;I see{tgm}...{tgm} {v:ClassArticle} <red>{e:DB.classes.get(u('{v:FortuneUnitChoice}').klass).name}</> wielding {v:WeaponArticle} <red>{v:FortuneWeapon}</>.|They also have the skill <red>{v:FortuneSkill}</>. That skill has this effect:|<red>{v:FortuneSkillDesc}</>|{c:e;OldWoman1;NormalBlink}That is all. Now, my payment?",
            "  mlvar;FortuneIntel;it.append(DB.classes.get(u('{v:FortuneUnitChoice}').klass).name)",
            "  mlvar;FortuneIntel;it.append('{v:FortuneWeapon}')",
            "  mlvar;FortuneIntel;it.append('{v:FortuneSkill}')",
            "  mlvar;Fortunes;it.update({v('FortuneUnitChoice'):True})",
            "else",
            "  trigger_script;0 Fortune Telling",
            "end"
        ],
        "nid": "0 Fortune Telling"
    }
]