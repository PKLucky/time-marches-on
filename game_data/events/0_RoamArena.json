[
    {
        "name": "RoamArena",
        "trigger": "Arena",
        "level_nid": "0",
        "condition": "game.is_roam() == True",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "# Get the NIDs and positions of all units on the map and store them into variables. This will be used to put the units back after the arena battle.",
            "if;v('TutorialFirst')['Arena'] != True",
            "  u;ArenaMan;Right",
            "  s;ArenaMan;Hey! This is the <red>Arena</>. Battle it out with a random opponent and earn some cash.|What? Dying? Nah, nah, it's all <red>non-lethal</>.|What kinda establishment d'ya think we're runnin'?|By the way, <red>Staff wielders can enter too</>. We'll supply 'em with an <red>Assault</> Staff.",
            "  r;ArenaMan",
            "  if;v('TutorialFirst')['AP'] != True",
            "    trigger_script;0 AP Tutorial Tip",
            "  end",
            "  if;u('Lord').klass == 'Lord' and u('Player').klass == 'Veteran'",
            "    if;v('TutorialFirst')['ClassChange'] == True",
            "      s;;If you want to win, I highly recommend talking to one of the <red>Re-Classy Siblings</> before entering.;;;hint",
            "    else",
            "      s;;If you want to win, I highly recommend talking to one of those <red>weird green guys</> before entering.;;140;hint",
            "    end",
            "  end",
            "  add_lore;Arena",
            "  mlvar;TutorialFirst;it.update({'Arena':True})",
            "end",
            "if;item_funcs.num_stacks(u('Lord'),'ActivityPoints') >= 2",
            "  textbox;APDisplay;str(item_funcs.num_stacks(u('Lord'),'ActivityPoints')) + ' AP';top_left;60;expression",
            "  choice;ArenaChoice;Enter the arena? (Cost: 2 AP);Yes,No;backable",
            "  remove_table;APDisplay",
            "  if;v('ArenaChoice') != 'Yes'",
            "    finish",
            "  end",
            "  choice;ArenaFighter;Who will enter the arena?;Lord|{v:LordName},Player|{v:JagenName};EntryType=type_unit;backable",
            "  if;v('ArenaFighter') == 'BACK'",
            "    finish",
            "  end",
            "  move_unit;Lord;4,10;immediate;stack",
            "  move_unit;Player;4,10;immediate;closest",
            "  level_var;SavedUnitNids;[unit.nid for unit in game.get_all_units()]",
            "  level_var;SavedUnitPositions;[unit.position for unit in game.get_all_units()]",
            "  level_var;WeaponDict;{'Sword':'Iron_Sword','Lance':'Iron_Lance','Axe':'Iron_Axe','Bow':'Iron_Bow','Anima':'Fire','Light':'Lightning','Dark':'Flux','Staff':'Assault'}",
            "  transition;Close",
            "  remove_all_units",
            "  # Find tier of class of player unit to determine enemy's tier",
            "  level_var;EnemyTier;DB.classes.get(u('{v:ArenaFighter}').klass).tier",
            "  # Randomly choose the enemy's class from the pool. Add the tag ArenaIgnore to any classes that won't show up in the arena.",
            "  level_var;ArenaEnemyKlassList;[klass.nid for klass in DB.classes if 'ArenaIgnore' not in klass.tags and klass.tier == game.level_vars['EnemyTier']]",
            "  level_var;KlassRNG;game.get_random(0, len(game.level_vars['ArenaEnemyKlassList']) - 1)",
            "  level_var;ArenaEnemyKlass;game.level_vars['ArenaEnemyKlassList'][game.level_vars['KlassRNG']]",
            "# Calculate level range for enemy and pick level at random",
            "  level_var;low_level;max(1,u('{v:ArenaFighter}').level - 4)",
            "  level_var;high_level;min(20,u('{v:ArenaFighter}').level + 4)",
            "  level_var;EnemyLevel;game.get_random(game.level_vars['low_level'],game.level_vars['high_level'])",
            "  # Calculate arena wager based on enemy level",
            "  level_var;ArenaPercent;(game.level_vars['EnemyLevel'] - game.level_vars['low_level']) / float(game.level_vars['high_level'] - game.level_vars['low_level'])",
            "  level_var;ArenaWager;int(min(550 + game.level_vars['ArenaPercent'] * (1100 - 550), game.get_money()))",
            "  # Spawn enemy",
            "  make_generic;;{v:ArenaEnemyKlass};{v:EnemyLevel};enemy;None;Enemy",
            "  # Equip enemy with weapon. Determines what weapons are available to equip based on usability defined in the Class Editor.",
            "  for;LoadItem;[w for w in DB.classes.get(u('{created_unit}').klass).wexp_gain if DB.classes.get(u('{created_unit}').klass).wexp_gain[w].usable == True]",
            "    set_wexp;{created_unit};{LoadItem};1;no_banner",
            "    give_item;{created_unit};{e:game.level_vars['WeaponDict']['{LoadItem}']};no_banner",
            "  endf",
            "  # Randomly choose which weapon to equip.",
            "  level_var;InventorySlot;game.get_random(0,len(u('{created_unit}').items))",
            "  equip_item;{created_unit};{e:u('{created_unit}').items[{v:InventorySlot}]}",
            "  change_background;Arena",
            "  draw_overlay_sprite;ArenaPortrait;arena_portrait;4,4;1",
            "  table;GoldDisplay;game.get_money();;;60;right;funds_display;;center;expression",
            "  # Fade to arena background",
            "  transition;open",
            "  music;Arena Entrance",
            "  if;game.get_money() == 0",
            "    speak;;What! You don't have any money! Get out of here!;top_right;160;noir",
            "  else",
            "    speak;;Welcome to the arena!;top_right;160;noir",
            "    # Get name of class to display on table",
            "    level_var;ArenaEnemyKlass;DB.classes.get(game.get_unit('{created_unit}').klass).name",
            "    level_var;ArenaItem;u('{created_unit}').get_weapon().name",
            "    textbox;OpponentStats;Opponent: {v:ArenaEnemyKlass} - {v:ArenaItem}{br}Level: {e:u('{created_unit}').level};bottom;200;2",
            "    choice;ArenaChoice;Would you like to wager {var:ArenaWager} gold?;Yes,No;backable",
            "    if;game.game_vars['ArenaChoice'] == 'Yes'",
            "      choice;ArenaFighterWeapon;What weapon will {e:u('{v:ArenaFighter}').name} wield?;[w for w in DB.classes.get(u('{v:ArenaFighter}').klass).wexp_gain if DB.classes.get(u('{v:ArenaFighter}').klass).wexp_gain[w].usable == True];Dimensions=3,3;expression;backable",
            "      if;v('ArenaFighterWeapon') == 'BACK'",
            "        speak;;What are you wasting my time for?;top_right;160;noir",
            "        # Clean up after a round at the arena.",
            "        change_background",
            "        remove_unit;{created_unit};immediate",
            "        remove_table;GoldDisplay",
            "        remove_overlay_sprite;ArenaPortrait",
            "        for;ReturnUnits;range(0,len(game.level_vars['SavedUnitNids']))",
            "          add_unit;{e:game.level_vars['SavedUnitNids'][{ReturnUnits}]};{e:game.level_vars['SavedUnitPositions'][{ReturnUnits}]};immediate;stack",
            "        endf",
            "        transition;open",
            "        music_fade_back",
            "        change_roaming;True",
            "        finish",
            "      end",
            "      give_item;{v:ArenaFighter};{e:game.level_vars['WeaponDict']['{v:ArenaFighterWeapon}']};no_banner",
            "      sound;GoldExchange",
            "      give_money;{e:-game.level_vars['ArenaWager']};no_banner",
            "      speak;;Good luck.{br}Best man standing wins.|Fight 'til the end or press CANCEL to yield.;top_right;160;noir",
            "      remove_table;OpponentStats",
            "      transition;close",
            "      change_background",
            "      add_unit;{v:ArenaFighter};{position};immediate;stack",
            "      #Moves the unit away from the player unit so they can retaliate if equipped with a bow.",
            "      if;game.get_unit('{created_unit}').get_weapon().weapon_type.value == 'Bow'",
            "        add_unit;{created_unit};{e:game.get_unit('{v:ArenaFighter}').position[0] - 1},{e:game.get_unit('{v:ArenaFighter}').position[1] - 1};immediate;stack",
            "      else",
            "        add_unit;{created_unit};{v:ArenaFighter};immediate;closest",
            "      end",
            "      interact_unit;{v:ArenaFighter};{created_unit};;;50;arena;force_animation",
            "      end_skip",
            "      change_background;Arena",
            "      transition;open",
            "      if;game.check_dead('{created_unit}')",
            "        music;Arena Victory",
            "        if;v('Month') >= 6 and v('Month') <= 8",
            "        speak;;So you won, eh? Here's your prize. {e:4*game.level_vars['ArenaWager']} gold.;top_right;160;noir",
            "        else",
            "        speak;;So you won, eh? Here's your prize. {e:2*game.level_vars['ArenaWager']} gold.;top_right;160;noir",
            "        end",
            "        sound;GoldExchange",
            "        if;v('Month') >= 6 and v('Month') <= 8",
            "          give_money;{e:4*game.level_vars['ArenaWager']}",
            "        else",
            "          give_money;{e:2*game.level_vars['ArenaWager']}",
            "        end",
            "        music_fade_back;100",
            "      else",
            "        resurrect;{v:ArenaFighter}",
            "        speak;;Ouch, that's not good. Better luck next time.;top_right;160;noir",
            "      end",
            "      set_current_hp;{v:ArenaFighter};99",
            "      remove_skill;Lord;ActivityPoints;2;no_banner",
            "    else",
            "      speak;;What are you wasting my time for?;top_right;160;noir",
            "      remove_table;OpponentStats",
            "    end",
            "  end",
            "  transition;close",
            "  # Clean up after a round at the arena.",
            "  change_background",
            "  remove_unit;{created_unit};immediate",
            "  remove_unit;DUMMY;immediate",
            "  remove_table;GoldDisplay",
            "  remove_overlay_sprite;ArenaPortrait",
            "  remove_item;{v:ArenaFighter};{e:game.level_vars['WeaponDict']['{v:ArenaFighterWeapon}']};no_banner",
            "  for;ReturnUnits;range(0,len(game.level_vars['SavedUnitNids']))",
            "    add_unit;{e:game.level_vars['SavedUnitNids'][{ReturnUnits}]};{e:game.level_vars['SavedUnitPositions'][{ReturnUnits}]};immediate;stack",
            "  endf",
            "  transition;open",
            "  music_fade_back",
            "  change_roaming;True",
            "else",
            "  sound;Error",
            "  alert;Not enough AP!",
            "end"
        ],
        "nid": "0 RoamArena"
    }
]