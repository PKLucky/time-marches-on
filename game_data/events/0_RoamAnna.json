            "  r;Anna",
            "  add_lore;AnnaShop",
            "  mlvar;TutorialFirst;it.update({'Anna':True})",
            "end",
            "if;len(v('AnnaStock')) == 0 and v('AnnaVisit') == True",
            "  u;Anna;Right",
            "  s;Anna;That's it for my stock this month. Sorry!",
