        "_source": [
            "if;v('TutorialFirst')['Mining'] != True",
            "  u;Man3;Right",
            "  s;Man3;Yo, welcome to the <red>mines</>. You can try your luck at digging up precious gems.|I'll buy whatever you manage to find. Wanna give it a whirl?|Don't think it's gonna be easy, though. If it were, we'd all be rich 'round here, haha!",
            "  r;Man3",
            "  add_lore;Mining",
            "  mlvar;TutorialFirst;it.update({'Mining':True})",
            "end",
            "if;v('TutorialFirst')['AP'] != True",
            "  trigger_script;0 AP Tutorial Tip",
            "end",
            "if;item_funcs.num_stacks(u('Lord'),'ActivityPoints') >= 1",
            "  textbox;APDisplay;str(item_funcs.num_stacks(u('Lord'),'ActivityPoints')) + ' AP';top_left;60;expression",
            "  choice;MiningChoice;Want to go mining? (Cost: 1 AP);Yes,No",
            "  remove_table;APDisplay",
            "  if;v('MiningChoice') == 'Yes'",
            "    s;;You begin to dig...;;110;hint;NumLines=1",
            "    end_skip",
            "    if;v('Month') >= 9 and v('Month') <= 11",
            "      lvar;MiningOdds;[17,14,12,10,7,40]",
            "    else",
            "      lvar;MiningOdds;[12,10,8,6,4,60]",
            "    end",
            "    lvar;MiningResult;game.get_random_weighted_choice(['Red_Gem','Blue_Gem','White_Gem','Black_Gem','Gold_Gem','nothing'],v('MiningOdds'))",
            "    if;v('MiningResult') == 'nothing'",
            "      sound;ItemBreak",
            "      alert;You got nothing...",
            "      u;Man3;Right",
            "      s;Man3;Too bad.",
            "    else",
            "      sound;Item",
            "      alert;You get a {e:DB.items.get('{v:MiningResult}').name}!;{v:MiningResult}",
            "      give_money;{e:DB.items.get('{v:MiningResult}').value.value // 2}",
            "    end",
            "    remove_skill;Lord;ActivityPoints;1;no_banner",
            "  end",
            "else",
            "  sound;Error",
            "  alert;Not enough AP!",
            "end",
            "u;Man3;Right",
            "s;Man3;Come again soon!",
            "r;Man3"
