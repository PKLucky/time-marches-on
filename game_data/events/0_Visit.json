        "priority": 20,
        "_source": [
            "if;game.is_roam() == True",
            "  if;v('TutorialFirst')['Fishing'] != True",
            "    u;OldMan1;Right",
            "    s;OldMan1;Hey, hey, welcome to the <red>Fishing Hole</>. Wanna cast a line? I'll buy any fish you catch.|Sometimes stuff from the neighboring shops washes up here too.|Who knows what you'll get!",
            "    r;OldMan1",
            "    if;v('TutorialFirst')['AP'] != True",
            "      trigger_script;0 AP Tutorial Tip",
            "    end",
            "    mlvar;TutorialFirst;it.update({'Fishing':True})",
            "    add_lore;Fishing",
            "  end",
            "  if;(v('Month') < 9 and item_funcs.num_stacks(u('Lord'),'ActivityPoints') >= 1) or (item_funcs.num_stacks(u('Lord'),'ActivityPoints') >= 2 and v('Month') >= 9)",
            "    textbox;APDisplay;str(item_funcs.num_stacks(u('Lord'),'ActivityPoints')) + ' AP';top_left;60;expression",
            "    if;v('Month') >= 9",
            "      choice;FishingChoice;Want to go fish? (Cost: 2 AP);Yes,No;backable",
            "    else",
            "      choice;FishingChoice;Want to go fish? (Cost: 1 AP);Yes,No;backable",
            "    end",
            "    remove_table;APDisplay",
            "    if;v('FishingChoice') == 'Yes'",
            "      s;;You cast your line...;;120;hint;NumLines=1",
            "      end_skip",
            "      if;v('Month') >= 3 and v('Month') <= 5",
