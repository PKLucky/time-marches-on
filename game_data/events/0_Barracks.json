        "_source": [
            "# For raising weapon levels. Player chooses which weapons to level up.",
            "if;v('TutorialFirst')['Barracks'] != True",
            "  u;Man1;Right",
            "  s;Man1;Welcome to the <red>Barracks</>. Here, you practice using different weapons.|You can practice using any weapon, even if it's one your class doesn't typically wield.|You also get a bit of battle experience too. Wanna give it a try?",
            "  r;Man1",
            "    if;v('TutorialFirst')['AP'] != True",
            "      trigger_script;0 AP Tutorial Tip",
            "    end",
            "    if;u('Lord').klass == 'Lord' and u('Player').klass == 'Veteran'",
            "      if;v('TutorialFirst')['ClassChange'] == True",
            "        s;;I recommend talking to one of the <red>Re-Classy Siblings</> first to get the most out of this.;;;hint",
            "      else",
            "        s;;I recommend talking to one of those <red>weird green guys</> first to get the most out of this.;;;hint",
            "      end",
            "    end",
            "  add_lore;Barracks",
            "  mlvar;TutorialFirst;it.update({'Barracks':True})",
            "end",
            "if;item_funcs.num_stacks(u('Lord'),'ActivityPoints') >= 1",
            "  textbox;APDisplay;str(item_funcs.num_stacks(u('Lord'),'ActivityPoints')) + ' AP';top_left;60;expression",
            "  choice;BarracksChoice;Train at the barracks? (Cost: 1 AP);Yes,No;backable",
            "  if;v('BarracksChoice') == 'Yes'",
            "    remove_table;APDisplay",
            "    trigger_script;0 Barracks Choice;Lord",
            "    if;v('WeaponChoice') == 'BACK'",
            "      u;Man1;Right",
            "      s;Man1;See ya 'round.",
            "      r;Man1",
            "      finish",
            "    end",
            "    trigger_script;0 Barracks Choice;Player",
            "    if;v('WeaponChoice') == 'BACK'",
            "      u;Man1;Right",
            "      s;Man1;See ya 'round.",
            "      r;Man1",
            "      finish",
            "    end",
            "    if;v('LordWeapon') in [w for w in DB.classes.get(u('Lord').klass).wexp_gain if DB.classes.get(u('Lord').klass).wexp_gain[w].usable == True] and u('Lord').klass != 'Lord'",
            "      lvar;WEXPBarracks;[v('WEXPBarracksBase')[0]*2,v('WEXPBarracksBase')[1]*2,v('WEXPBarracksBase')[2]*2]",
            "    else",
            "      lvar;WEXPBarracks;[v('WEXPBarracksBase')[0],v('WEXPBarracksBase')[1],v('WEXPBarracksBase')[2]]",
            "    end",
            "    lvar;LordWEXP;game.get_random_weighted_choice(v('WEXPBarracks'),[7.5,2,0.5])",
            "    if;v('JagenWeapon') in [w for w in DB.classes.get(u('Player').klass).wexp_gain if DB.classes.get(u('Player').klass).wexp_gain[w].usable == True] and u('Player').klass != 'Veteran'",
            "      lvar;WEXPBarracks;[v('WEXPBarracksBase')[0]*6,v('WEXPBarracksBase')[1]*6,v('WEXPBarracksBase')[2]*6]",
            "    else",
            "      lvar;WEXPBarracks;[v('WEXPBarracksBase')[0]*3,v('WEXPBarracksBase')[1]*3,v('WEXPBarracksBase')[2]*3]",
            "    end",
            "    lvar;JagenWEXP;game.get_random_weighted_choice(v('WEXPBarracks'),[7.5,2,0.5])",
