[
    {
        "name": "Skill_Learn",
        "trigger": null,
        "level_nid": null,
        "condition": "True",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "lvar;LearnedSkillList;u('{unit}').get_field('LearnedSkills')",
            "game_var;NewSkillToSwapIn;DB.items.get(item.nid).nid[6:]",
            "give_skill;{unit};{v:NewSkillToSwapIn}",
            "# Add skill to unit's list of learned skills",
            "mlvar;LearnedSkillList;it.append('{v:NewSkillToSwapIn}')",
            "set_unit_field;{unit};LearnedSkills;{v:LearnedSkillList}",
            "# Add skill to list of equipped skills if less than 3 skills, otherwise, prompt to swap out a skill.",
            "if;len(unit.get_field('EquippedSkills')) == 5",
            "  trigger_script;Global Skill_Swap_Unlock;{unit}",
            "elif;len(unit.get_field('EquippedSkills')) == 0",
            "  set_unit_field;{unit};EquippedSkills;['{v:NewSkillToSwapIn}']",
            "else",
            "  set_unit_field;{unit};EquippedSkills;{v:LearnedSkillList}",
            "end"
        ],
        "nid": "Global Skill_Learn"
    }
]